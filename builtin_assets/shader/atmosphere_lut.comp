#version 450
#extension GL_GOOGLE_include_directive : enable
#extension GL_EXT_scalar_block_layout : enable

#define ATMOSPHERE_DESCRIPTOR_SET 0
#define ATMOSPHERE_NO_PUSH_CONSTANT
#define ATMOSPHERE_CORE_ONLY
#define ATMOSPHERE_EXPLICIT_LOD
#include "atmosphere.glsl"

const int TRANSMITTANCE_SAMPLE_COUNT = 32;
const int DIRECTION_SAMPLE_COUNT = 64;
const int SCATTERING_SAMPLE_COUNT = 32;

layout(set = 0, binding = 2, rgba16f) writeonly uniform image2D transmittanceImage;
layout(set = 0, binding = 3, rgba16f) writeonly uniform image2D scatteringImage;
layout(push_constant) uniform PushConstants
{
    uint pass;
};

vec2 UvToTransmittanceLutParams(float bottomRadius, float topRadius, vec2 uv)
{
    float H = sqrt(max(0.0, topRadius * topRadius - bottomRadius * bottomRadius));
    float rho = H * uv.y;
    float r = sqrt(max(0.0, rho * rho + bottomRadius * bottomRadius));
    float dMin = topRadius - r;
    float dMax = rho + H;
    float d = mix(dMin, dMax, uv.x);
    float mu = d == 0.0 ? 1.0 :
        (H * H - rho * rho - d * d) / (2.0 * r * d);
    return vec2(clamp(mu, -1.0, 1.0), r);
}

vec3 IntegrateTransmittance(vec3 start, vec3 end)
{
    vec3 direction = normalize(end - start);
    float distanceToEnd = length(end - start);
    float stepLength = distanceToEnd / float(TRANSMITTANCE_SAMPLE_COUNT);
    vec3 opticalDepth = vec3(0.0);
    vec3 p = start + direction * stepLength * 0.5;
    for (int i = 0; i < TRANSMITTANCE_SAMPLE_COUNT; ++i)
    {
        float h = length(p) - parameters.planetRadius;
        opticalDepth += (RayleighCoefficient(h) + MieCoefficient(h) +
                         OzoneAbsorption(h) + MieAbsorption(h)) * stepLength;
        p += direction * stepLength;
    }
    return exp(-opticalDepth);
}

