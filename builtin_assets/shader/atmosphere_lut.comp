vec3 IntegrateMultiScattering(vec3 samplePoint, vec3 lightDir)
{
    const float uniformPhase = 1.0 / (4.0 * PI);
    const float sphereSolidAngle = 4.0 * PI / float(DIRECTION_SAMPLE_COUNT);
    vec3 secondOrderScattering = vec3(0.0);
    vec3 multiScatteringFactor = vec3(0.0);

    for (int i = 0; i < DIRECTION_SAMPLE_COUNT; ++i)
    {
        vec3 viewDir = DIRECTION_SAMPLES[i];
        float distanceToAtmosphere = RayIntersectSphere(
            vec3(0.0), parameters.planetRadius + parameters.atmosphereHeight, samplePoint, viewDir);
        float distanceToGround = RayIntersectSphere(
            vec3(0.0), parameters.planetRadius, samplePoint, viewDir);
        if (distanceToGround > 0.0)
            distanceToAtmosphere = min(distanceToAtmosphere, distanceToGround);
        if (distanceToAtmosphere <= 0.0)
            continue;

        float stepLength = distanceToAtmosphere / float(SCATTERING_SAMPLE_COUNT);
        vec3 p = samplePoint + viewDir * stepLength * 0.5;
        vec3 opticalDepth = vec3(0.0);
        for (int j = 0; j < SCATTERING_SAMPLE_COUNT; ++j)
        {
            float h = length(p) - parameters.planetRadius;
            if (h < 0.0)
                break;
            vec3 sigmaS = RayleighCoefficient(h) + MieCoefficient(h);
            vec3 sigmaT = sigmaS + OzoneAbsorption(h) + MieAbsorption(h);
            opticalDepth += sigmaT * stepLength;

            vec3 pathTransmittance = exp(-opticalDepth);
            secondOrderScattering += TransmittanceToAtmosphere(p, lightDir) *
                Scattering(p, lightDir, viewDir) * pathTransmittance *
                uniformPhase * stepLength;
            multiScatteringFactor += pathTransmittance * sigmaS *
                uniformPhase * stepLength;
            p += viewDir * stepLength;
        }
    }

    secondOrderScattering *= sphereSolidAngle;
    multiScatteringFactor *= sphereSolidAngle;
    return secondOrderScattering / max(vec3(1e-4), vec3(1.0) - multiScatteringFactor);
}

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;
void main()
{
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    if (pass == 0u)
    {
        ivec2 extent = imageSize(transmittanceImage);
        if (any(greaterThanEqual(pixel, extent)))
            return;
        vec2 uv = (vec2(pixel) + 0.5) / vec2(extent);
        float bottomRadius = parameters.planetRadius;
        float topRadius = bottomRadius + parameters.atmosphereHeight;
        vec2 lutParams = UvToTransmittanceLutParams(bottomRadius, topRadius, uv);
        float mu = lutParams.x;
        float r = lutParams.y;
        vec3 viewDir = vec3(sqrt(max(0.0, 1.0 - mu * mu)), mu, 0.0);
        vec3 eyePos = vec3(0.0, r, 0.0);
        float distanceToAtmosphere = RayIntersectSphere(
            vec3(0.0), topRadius, eyePos, viewDir);
        vec3 value = IntegrateTransmittance(
            eyePos, eyePos + viewDir * distanceToAtmosphere);
        imageStore(transmittanceImage, pixel, vec4(value, 1.0));
        return;
    }

    ivec2 extent = imageSize(scatteringImage);
    if (any(greaterThanEqual(pixel, extent)))
        return;
    vec2 uv = (vec2(pixel) + 0.5) / vec2(extent);
    float mu = uv.x * 2.0 - 1.0;
    float r = parameters.planetRadius + uv.y * parameters.atmosphereHeight;
    vec3 lightDir = vec3(sqrt(max(0.0, 1.0 - mu * mu)), mu, 0.0);
    vec3 value = IntegrateMultiScattering(vec3(0.0, r, 0.0), lightDir);
    imageStore(scatteringImage, pixel, vec4(clamp(value, 0.0, 1.0), 1.0));
}
